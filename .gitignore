# =============================================================================
# VoiceTask — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# 🔐 SECRETS — NEVER COMMIT THESE
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example          # allow the safe template

# Firebase service account private key
serviceAccountKey.json
*serviceAccount*.json
*.key
*.pem
*.p12
*.pfx

# -----------------------------------------------------------------------------
# 🐍 Python / Backend
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/
.dmypy.json

# Whisper model cache (downloaded at runtime, ~1.5 GB)
# These live in ~/.cache/huggingface by default — not in the repo

# -----------------------------------------------------------------------------
# 🌐 Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/

# Vite cache
.vite/

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json   # optional: remove this line if you want to commit lockfile

# -----------------------------------------------------------------------------
# 🖥️ OS / Editor
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# VSCode
.vscode/
!.vscode/extensions.json   # allow shared extension recommendations

# JetBrains IDEs
.idea/
*.iml

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# -----------------------------------------------------------------------------
# 📋 Logs & Temp
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
